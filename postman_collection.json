{
	"info": {
		"name": "Lawyer App API",
		"description": "Complete API collection for Lawyer App",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Admin",
			"item": [
				{"name": "Create Admin", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"adminId\": \"admin123\",\n  \"password\": \"test123\",\n  \"name\": \"Test Admin\"\n}"}, "url": {"raw": "http://localhost:5001/api/admin/create", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "admin", "create"]}}},
				{"name": "Admin Login", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"adminId\": \"admin123\",\n  \"password\": \"test123\"\n}"}, "url": {"raw": "http://localhost:5001/api/admin/login", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "admin", "login"]}}},
				{"name": "List Admins", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}], "url": {"raw": "http://localhost:5001/api/admin/list", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "admin", "list"]}}},
				{"name": "Logout All Sessions", "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}], "url": {"raw": "http://localhost:5001/api/admin/logout-all", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "admin", "logout-all"]}}}
			]
		},
		{
			"name": "Lawyer",
			"item": [
				{"name": "Register Lawyer", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"full_name\": \"Rajesh Kumar\",\n  \"mobile_number\": \"9876543210\",\n  \"email\": \"rajesh@lawyer.com\",\n  \"password\": \"test123\",\n  \"bar_council_number\": \"BAR12345\",\n  \"bar_council_state\": \"Delhi\",\n  \"years_of_experience\": 5,\n  \"specialization\": \"Criminal Law\",\n  \"classification\": \"Criminal\",\n  \"office_address\": \"123 Court Road\",\n  \"city\": \"Delhi\",\n  \"state\": \"Delhi\",\n  \"pincode\": \"110001\"\n}"}, "url": {"raw": "http://localhost:5001/api/lawyers/register", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "lawyers", "register"]}}},
				{"name": "Lawyer Login", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"mobile_number\": \"9876543210\",\n  \"password\": \"test123\"\n}"}, "url": {"raw": "http://localhost:5001/api/lawyers/login", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "lawyers", "login"]}}},
				{"name": "Get Lawyer Profile", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{lawyer_token}}"}], "url": {"raw": "http://localhost:5001/api/lawyers/profile", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "lawyers", "profile"]}}},
				{"name": "Update Lawyer Profile", "request": {"method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{lawyer_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"about_lawyer\": \"Experienced criminal lawyer\",\n  \"consultation_fee\": 2000,\n  \"languages_spoken\": [\"Hindi\", \"English\"],\n  \"sub_classification\": \"Property Law\"\n}"}, "url": {"raw": "http://localhost:5001/api/lawyers/profile", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "lawyers", "profile"]}}}
			]
		},
		{
			"name": "User (OTP Login)",
			"item": [
				{"name": "Send OTP", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"mobile_number\": \"9999999999\"\n}"}, "url": {"raw": "http://localhost:5001/api/users/send-otp", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "users", "send-otp"]}}},
				{"name": "Verify OTP & Login", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"mobile_number\": \"9999999999\",\n  \"otp\": \"123456\"\n}"}, "url": {"raw": "http://localhost:5001/api/users/verify-otp", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "users", "verify-otp"]}}},
				{"name": "Get User Profile", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{user_token}}"}], "url": {"raw": "http://localhost:5001/api/users/profile", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "users", "profile"]}}},
				{"name": "Update User Profile", "request": {"method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{user_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\"\n}"}, "url": {"raw": "http://localhost:5001/api/users/profile", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "users", "profile"]}}}
			]
		},
		{
			"name": "Services",
			"item": [
				{"name": "Add Service", "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{lawyer_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"service_name\": \"Legal Consultation\",\n  \"description\": \"One hour legal consultation\",\n  \"price\": 1500,\n  \"duration\": \"1 hour\"\n}"}, "url": {"raw": "http://localhost:5001/api/services", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "services"]}}},
				{"name": "Get My Services", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{lawyer_token}}"}], "url": {"raw": "http://localhost:5001/api/services/my-services", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "services", "my-services"]}}},
				{"name": "Update Service", "request": {"method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{lawyer_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"price\": 2000,\n  \"description\": \"Updated description\"\n}"}, "url": {"raw": "http://localhost:5001/api/services/:id", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "services", ":id"], "variable": [{"key": "id", "value": "{{service_id}}"}]}}},
				{"name": "Delete Service", "request": {"method": "DELETE", "header": [{"key": "Authorization", "value": "Bearer {{lawyer_token}}"}], "url": {"raw": "http://localhost:5001/api/services/:id", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "services", ":id"], "variable": [{"key": "id", "value": "{{service_id}}"}]}}},
				{"name": "Get Services by Lawyer (Public)", "request": {"method": "GET", "url": {"raw": "http://localhost:5001/api/services/lawyer/:lawyerId", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "services", "lawyer", ":lawyerId"], "variable": [{"key": "lawyerId", "value": "{{lawyer_id}}"}]}}}
			]
		},
		{
			"name": "Public APIs",
			"item": [
				{"name": "Get All Lawyers (Public)", "request": {"method": "GET", "url": {"raw": "http://localhost:5001/api/public/lawyers/all", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "public", "lawyers", "all"]}}},
				{"name": "Get Lawyer by ID (Public)", "request": {"method": "GET", "url": {"raw": "http://localhost:5001/api/public/lawyers/:id", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "public", "lawyers", ":id"], "variable": [{"key": "id", "value": "{{lawyer_id}}"}]}}}
			]
		},
		{
			"name": "Admin - Lawyer Management",
			"item": [
				{"name": "Get All Lawyers", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}], "url": {"raw": "http://localhost:5001/api/lawyers/all", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "lawyers", "all"]}}},
				{"name": "Update Lawyer by Admin", "request": {"method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"consultation_fee\": 3000\n}"}, "url": {"raw": "http://localhost:5001/api/lawyers/:id", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "lawyers", ":id"], "variable": [{"key": "id", "value": "{{lawyer_id}}"}]}}},
				{"name": "Toggle Lawyer Status", "request": {"method": "PATCH", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"isActive\": false\n}"}, "url": {"raw": "http://localhost:5001/api/lawyers/:id/status", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "lawyers", ":id", "status"], "variable": [{"key": "id", "value": "{{lawyer_id}}"}]}}},
				{"name": "Delete Lawyer", "request": {"method": "DELETE", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}], "url": {"raw": "http://localhost:5001/api/lawyers/:id", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "lawyers", ":id"], "variable": [{"key": "id", "value": "{{lawyer_id}}"}]}}},
				{"name": "Get All Lawyers with Services", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}], "url": {"raw": "http://localhost:5001/api/services/admin/all-lawyers-services", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "services", "admin", "all-lawyers-services"]}}}
			]
		},
		{
			"name": "Admin - User Management",
			"item": [
				{"name": "Get All Users", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}], "url": {"raw": "http://localhost:5001/api/users/admin/all", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "users", "admin", "all"]}}},
				{"name": "Update User by Admin", "request": {"method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Updated Name\",\n  \"email\": \"updated@example.com\"\n}"}, "url": {"raw": "http://localhost:5001/api/users/admin/:id", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "users", "admin", ":id"], "variable": [{"key": "id", "value": "{{user_id}}"}]}}},
				{"name": "Toggle User Status", "request": {"method": "PATCH", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"isActive\": false\n}"}, "url": {"raw": "http://localhost:5001/api/users/admin/:id/status", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "users", "admin", ":id", "status"], "variable": [{"key": "id", "value": "{{user_id}}"}]}}},
				{"name": "Delete User", "request": {"method": "DELETE", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}], "url": {"raw": "http://localhost:5001/api/users/admin/:id", "protocol": "http", "host": ["localhost"], "port": "5001", "path": ["api", "users", "admin", ":id"], "variable": [{"key": "id", "value": "{{user_id}}"}]}}}
			]
		}
	],
	"variable": [
		{"key": "admin_token", "value": "", "type": "string"},
		{"key": "lawyer_token", "value": "", "type": "string"},
		{"key": "user_token", "value": "", "type": "string"},
		{"key": "lawyer_id", "value": "", "type": "string"},
		{"key": "service_id", "value": "", "type": "string"},
		{"key": "user_id", "value": "", "type": "string"}
	]
}
